# ~/.config/setmeup/zshrc — managed by chezmoi (setmeup)
# Sourced from ~/.zshrc

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# ---------------------------------------------------------------------------
# Powerlevel10k instant prompt (must stay near top)
# ---------------------------------------------------------------------------
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
    source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ---------------------------------------------------------------------------
# Oh My Zsh
# ---------------------------------------------------------------------------
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
DISABLE_AUTO_UPDATE="true"

plugins=(
    git
    z
    command-not-found
    zsh-autosuggestions
    zsh-syntax-highlighting
)

source "$ZSH/oh-my-zsh.sh"

# ---------------------------------------------------------------------------
# History
# ---------------------------------------------------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=20000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt APPEND_HISTORY

{{ if eq .chezmoi.os "darwin" -}}
# macOS-specific settings
export CLICOLOR=1
{{ end -}}

# ---------------------------------------------------------------------------
# Path
# ---------------------------------------------------------------------------
export PATH="$HOME/.local/bin:$PATH"

# ---------------------------------------------------------------------------
# SSH Agent
# ---------------------------------------------------------------------------
export SSH_AUTH_SOCK="$HOME/.ssh/ssh_auth_sock"
if [ ! -S "$SSH_AUTH_SOCK" ] || ! ssh-add -l &>/dev/null; then
    rm -f "$SSH_AUTH_SOCK"
    eval "$(ssh-agent -a "$SSH_AUTH_SOCK")"
    ssh-add
fi

# ---------------------------------------------------------------------------
# Mise
# ---------------------------------------------------------------------------
if (( $+commands[mise] )); then
    eval "$(mise activate zsh)"
fi

# ---------------------------------------------------------------------------
# Aliases (sourced after mise so command -v sees mise-managed shims)
# ---------------------------------------------------------------------------
[ -f ~/.aliases ] && source ~/.aliases

# ---------------------------------------------------------------------------
# Auto-update check (daily)
# ---------------------------------------------------------------------------
_setmeup_check_updates() {
    local state_dir="$HOME/.local/state/setmeup"
    local stamp="$state_dir/last-check"
    local now=$(date +%s)

    mkdir -p "$state_dir"

    if [[ -f "$stamp" ]]; then
        local last=$(< "$stamp")
        local age=$(( now - last ))
        if (( age < 86400 )); then
            return
        fi
    fi

    echo "$now" > "$stamp"

    # Check for updates in the background, write to a flag file
    {
        if (( $+commands[chezmoi] )); then
            chezmoi git -- fetch --quiet
            local local_rev=$(chezmoi git -- rev-parse HEAD)
            local remote_rev=$(chezmoi git -- rev-parse '@{u}')
            if [[ -n "$local_rev" && -n "$remote_rev" && "$local_rev" != "$remote_rev" ]]; then
                touch "$state_dir/update-available"
            fi
        fi
    } >/dev/null 2>&1 &!

    # Show update notice from a previous check
    if [[ -f "$state_dir/update-available" ]]; then
        printf '\033[1;33m[setmeup]\033[0m Updates available — run: setmeup update (dotfiles + tools + skills)\n'
        rm -f "$state_dir/update-available"
    fi
}
_setmeup_check_updates

# ---------------------------------------------------------------------------
# Powerlevel10k config
# ---------------------------------------------------------------------------
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
