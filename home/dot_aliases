# Shared shell aliases — sourced by both .bashrc and .zshrc

# Git
alias gs='git status'
alias gb='git branch'
alias gl='git log --pretty=oneline'
alias gd='git diff'
alias gp='git pull'
alias gpo='git push origin'
alias gc='git rev-parse --abbrev-ref HEAD'
alias gco='git checkout '
alias gbs='git branch | grep -i'

# Docker
alias dc='docker compose'

# Utilities
alias rand='openssl rand -base64 16'
alias pc='pre-commit run -a'
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# Modern tool replacements (only alias if the tool is available)
command -v bat &>/dev/null && alias cat="bat"
command -v eza &>/dev/null && alias ls="eza --icons" && alias ll="eza -l --icons" && alias la="eza -la --icons"
command -v fd  &>/dev/null && alias find="fd"
command -v rg  &>/dev/null && alias grep="rg"

# setmeup
alias setmeup='~/.local/bin/setmeup-update.sh'
