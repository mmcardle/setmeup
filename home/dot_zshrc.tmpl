# ~/.zshrc — managed by chezmoi (setmeup)
# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# ---------------------------------------------------------------------------
# History
# ---------------------------------------------------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=20000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt APPEND_HISTORY

# ---------------------------------------------------------------------------
# Completion
# ---------------------------------------------------------------------------
autoload -Uz compinit
compinit

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# ---------------------------------------------------------------------------
# Prompt
# ---------------------------------------------------------------------------
autoload -Uz promptinit
promptinit
PROMPT='%F{green}%n@%m%f:%F{blue}%~%f%# '

# ---------------------------------------------------------------------------
# Key bindings
# ---------------------------------------------------------------------------
bindkey -e

{{ if eq .chezmoi.os "darwin" -}}
# macOS-specific settings
export CLICOLOR=1
{{ end -}}

# ---------------------------------------------------------------------------
# Aliases
# ---------------------------------------------------------------------------
[ -f ~/.aliases ] && source ~/.aliases

# ---------------------------------------------------------------------------
# Path
# ---------------------------------------------------------------------------
export PATH="$HOME/.local/bin:$PATH"

# ---------------------------------------------------------------------------
# Mise
# ---------------------------------------------------------------------------
if (( $+commands[mise] )); then
    eval "$(mise activate zsh)"
fi

# ---------------------------------------------------------------------------
# Auto-update check (daily)
# ---------------------------------------------------------------------------
_setmeup_check_updates() {
    local state_dir="$HOME/.local/state/setmeup"
    local stamp="$state_dir/last-check"
    local now=$(date +%s)

    mkdir -p "$state_dir"

    if [[ -f "$stamp" ]]; then
        local last=$(< "$stamp")
        local age=$(( now - last ))
        if (( age < 86400 )); then
            return
        fi
    fi

    echo "$now" > "$stamp"

    # Check for updates in the background, write to a flag file
    {
        if (( $+commands[chezmoi] )); then
            chezmoi git -- fetch --quiet 2>/dev/null
            local local_rev=$(chezmoi git -- rev-parse HEAD 2>/dev/null)
            local remote_rev=$(chezmoi git -- rev-parse '@{u}' 2>/dev/null)
            if [[ -n "$local_rev" && -n "$remote_rev" && "$local_rev" != "$remote_rev" ]]; then
                touch "$state_dir/update-available"
            fi
        fi
    } &!

    # Show update notice from a previous check
    if [[ -f "$state_dir/update-available" ]]; then
        printf '\033[1;33m[setmeup]\033[0m Updates available — run: setmeup update\n'
        rm -f "$state_dir/update-available"
    fi
}
_setmeup_check_updates

# ---------------------------------------------------------------------------
# Private/local settings (not managed by chezmoi)
# ---------------------------------------------------------------------------
[ -f ~/.secrets ] && source ~/.secrets
