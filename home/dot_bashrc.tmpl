# ~/.bashrc — managed by chezmoi (setmeup)
# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return ;;
esac

# ---------------------------------------------------------------------------
# History
# ---------------------------------------------------------------------------
HISTCONTROL=ignoreboth
HISTSIZE=10000
HISTFILESIZE=20000
shopt -s histappend

# ---------------------------------------------------------------------------
# Shell options
# ---------------------------------------------------------------------------
shopt -s checkwinsize
shopt -s globstar 2>/dev/null

# ---------------------------------------------------------------------------
# Prompt
# ---------------------------------------------------------------------------
if [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null; then
    PS1='\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
else
    PS1='\u@\h:\w\$ '
fi

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
fi

{{ if eq .chezmoi.os "darwin" -}}
# macOS-specific settings
export CLICOLOR=1
alias ls='ls -G'
{{ end -}}

# ---------------------------------------------------------------------------
# Aliases
# ---------------------------------------------------------------------------
[ -f ~/.aliases ] && . ~/.aliases

# ---------------------------------------------------------------------------
# Mise
# ---------------------------------------------------------------------------
if command -v mise >/dev/null 2>&1; then
    eval "$(mise activate bash)"
fi

# ---------------------------------------------------------------------------
# Auto-update check (daily)
# ---------------------------------------------------------------------------
_setmeup_check_updates() {
    local state_dir="$HOME/.local/state/setmeup"
    local stamp="$state_dir/last-check"
    local now
    now=$(date +%s)

    mkdir -p "$state_dir"

    if [ -f "$stamp" ]; then
        local last
        last=$(cat "$stamp")
        local age=$(( now - last ))
        if [ "$age" -lt 86400 ]; then
            return
        fi
    fi

    echo "$now" > "$stamp"

    # Check for updates in the background
    (
        if command -v chezmoi >/dev/null 2>&1; then
            chezmoi git -- fetch --quiet 2>/dev/null
            local local_rev remote_rev
            local_rev=$(chezmoi git -- rev-parse HEAD 2>/dev/null)
            remote_rev=$(chezmoi git -- rev-parse '@{u}' 2>/dev/null)
            if [ -n "$local_rev" ] && [ -n "$remote_rev" ] && [ "$local_rev" != "$remote_rev" ]; then
                printf '\033[1;33m[setmeup]\033[0m Updates available — run: setmeup update\n'
            fi
        fi
    ) &
}
_setmeup_check_updates
